{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Configuração do template jewelry-v1",
  "type": "object",
  "properties": {
    "typography": {
      "type": "string",
      "enum": ["classico-luxo", "editorial-moderno", "minimalista-contemporaneo"],
      "default": "classico-luxo"
    },
    "palette": {
      "type": "object",
      "properties": {
        "primary": { "type": "string" },
        "accent": { "type": "string" },
        "surface": { "type": "string" },
        "text": { "type": "string" }
      },
      "additionalProperties": false
    },
    "incentives": {
      "type": "object",
      "properties": {
        "pixDiscount": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "percent": { "type": "number", "default": 5, "minimum": 0, "maximum": 30 }
          }
        },
        "freeShippingMinCents": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "thresholdCents": { "type": "integer", "default": 50000 }
          }
        },
        "installments": {
          "type": "object",
          "properties": {
            "max": { "type": "integer", "default": 6, "minimum": 1, "maximum": 12 },
            "interestFree": { "type": "boolean", "default": true }
          }
        }
      }
    },
    "warranty": {
      "type": "object",
      "properties": {
        "defaultMonths": { "type": "integer", "default": 12 }
      }
    }
  }
}
