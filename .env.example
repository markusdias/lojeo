# Banco — local Postgres via docker-compose; produção: Neon connection string
DATABASE_URL=postgres://lojeo:lojeo@localhost:5432/lojeo

# Auth.js v5
AUTH_SECRET=change-me-in-production-32chars-min
AUTH_TRUST_HOST=true

# Google OAuth — criar em https://console.cloud.google.com
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Anthropic — em dev, vazio = mock provider; em produção, exigir
ANTHROPIC_API_KEY=

# Storage — driver: local | r2
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./.local-storage

# Cloudflare R2 (produção)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Resend (email transacional)
RESEND_API_KEY=

# Remove.bg — habilita checkbox "gerar versão sem fundo" no upload de imagens
# de produto. Vazio = feature oculta no admin (modo degradado, original sempre salva).
# Obter em https://www.remove.bg/api
# REMOVE_BG_KEY=

# Identificadores da instância
TENANT_ID=00000000-0000-0000-0000-000000000001
TEMPLATE_ID=jewelry-v1

# Tracking
NEXT_PUBLIC_TRACKING_ENDPOINT=/api/track

# Storefront branding — usados em emails transacionais e MP redirect URLs
STOREFRONT_STORE_NAME=Atelier
STOREFRONT_FROM_EMAIL=no-reply@lojeo.app
STOREFRONT_PUBLIC_URL=http://localhost:3000

# Mercado Pago (BR · Pix + cartão + boleto). Sem token: modo simulado.
# Painel: mercadopago.com.br/developers/panel
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

# Stripe (internacional). Fase 1.2 — coffee-v1.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Bling NF-e (OAuth2 client_credentials). Sem creds: NF-e mock 44 dígitos.
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=

# Olist Tiny (alternativa Bling). Token de longa duração.
OLIST_API_TOKEN=

# Pagar.me
PAGARME_API_KEY=

# Melhor Envio (frete BR). Token de aplicativo.
MELHOR_ENVIO_TOKEN=

# DHL Express (frete internacional). MyDHL API key. Sem key: quotes mock.
DHL_API_KEY=

# FedEx (frete internacional). API key. Sem key: quotes mock.
FEDEX_API_KEY=

# SendGrid (alternativa Resend)
SENDGRID_API_KEY=

# FaqZap (escalação chatbot → WhatsApp humano)
FAQZAP_API_TOKEN=

# Trigger.dev (jobs assíncronos: emails, embeddings, cron real)
TRIGGER_API_URL=
TRIGGER_API_KEY=

# Cron secret — header `x-cron-secret` pra scheduler externo chamar
# POST /api/cron/<task>. Gerar com: openssl rand -hex 32
CRON_SECRET=

# Migrations admin endpoint (POST /api/migrate). Vazio = sem auth (dev only).
MIGRATION_SECRET=

# Allowed origins pra CSRF (cross-origin admin requests). Comma-separated.
ALLOWED_ORIGINS=
